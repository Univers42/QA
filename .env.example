# MongoDB connection string
# Local dev: mongodb://localhost:27017/test_hub
# CI (Atlas): set in GitHub Actions secrets
MONGO_URI=mongodb://localhost:27017/test_hub

# Target environment for test execution
TEST_ENV=local

# Base URLs for each service under test
KONG_URL=http://localhost:8000
GOTRUE_URL=http://localhost:9999
POSTGREST_URL=http://localhost:3000
REALTIME_URL=http://localhost:4001
MINIO_URL=http://localhost:9000
FRONTEND_URL=http://localhost:5173

# Transcendence frontend testing
TT_BASE_URL=http://localhost:5173
TT_DEV_URL=
TT_PREVIEW_URL=
TT_STAGING_URL=
TT_LOGIN_PATH=/auth
TT_PROFILE_PATH=/profile
TT_LOBBY_PATH=/lobby
TT_CHAT_PATH=/chat
TT_NOT_FOUND_PATH=/__qa_missing_route__
TT_AUTH_API_PATTERN=**/auth/**
TT_COOKIE_NAMES=sb-access-token,sb-refresh-token,auth-token,session
TT_STORAGE_STATE_PATH=
TT_E2E_EMAIL=
TT_E2E_PASSWORD=
