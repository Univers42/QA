#!/bin/bash
# ── Prismatica QA · Pre-commit Hook ────────────────────────
# Validates staged files BEFORE creating a commit.
# Bypass: SKIP_PRE_COMMIT=1 git commit ...

set -e

HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
source "${HOOK_DIR}/log_hook.sh"

# ── Skip conditions ────────────────────────────────────────

if [ "${SKIP_PRE_COMMIT}" = "1" ]; then
    log_warn "Pre-commit hook skipped (SKIP_PRE_COMMIT=1)"
    exit 0
fi

# Skip during merge/rebase (automated commits)
if [ -f .git/MERGE_HEAD ] || [ -d .git/rebase-merge ] || [ -d .git/rebase-apply ]; then
    exit 0
fi

log_broadcast "Pre-commit · Prismatica QA"

ERRORS=0
WARNINGS=0

# Get list of staged files (excluding deleted)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=d 2>/dev/null)

if [ -z "${STAGED_FILES}" ]; then
    log_info "No staged files to check"
    exit 0
fi

# Get only staged Python files for ruff
STAGED_PY=$(echo "${STAGED_FILES}" | grep '\.py$' || true)

# ── Check 1: Merge conflict markers ───────────────────────

log_debug "Checking for merge conflict markers..."
for file in ${STAGED_FILES}; do
    if grep -qnE '^(<<<<<<<|=======|>>>>>>>)' "${file}" 2>/dev/null; then
        log_error "Merge conflict marker found: ${file}"
        ERRORS=$((ERRORS + 1))
    fi
done

# ── Ruff checks — only enforce on main branch ─────────────
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")

if [ "${CURRENT_BRANCH}" = "main" ]; then
    # ── Check 2: Ruff lint (PEP 8) ────────────────────────────
    if [ -n "${STAGED_PY}" ] && [ -x ".venv/bin/ruff" ]; then
        log_debug "Running ruff linter on staged Python files..."

        # Run ruff check on staged files only
        RUFF_OUTPUT=$(.venv/bin/ruff check --no-fix ${STAGED_PY} 2>&1 || true)

        if [ -n "${RUFF_OUTPUT}" ]; then
            LINT_ERRORS=$(echo "${RUFF_OUTPUT}" | grep -cE "^.+\.py:" || echo "0")
            log_error "Ruff found ${LINT_ERRORS} issue(s):"
            echo ""
            echo "${RUFF_OUTPUT}" | while IFS= read -r line; do
                echo -e "    ${_D}${line}${_N}"
            done
            echo ""
            log_example "Auto-fix: .venv/bin/ruff check --fix core/ runner/ api/ cli/"
            log_example "Format:   .venv/bin/ruff format core/ runner/ api/ cli/"
            ERRORS=$((ERRORS + 1))
        else
            log_success "Ruff lint passed (PEP 8 compliant)"
        fi
    elif [ -n "${STAGED_PY}" ]; then
        log_warn "Ruff not installed — skipping PEP 8 check (run: make install)"
    fi

    # ── Check 3: Ruff format check ────────────────────────────

    if [ -n "${STAGED_PY}" ] && [ -x ".venv/bin/ruff" ]; then
        log_debug "Checking formatting..."

        FORMAT_OUTPUT=$(.venv/bin/ruff format --check ${STAGED_PY} 2>&1 || true)

        if echo "${FORMAT_OUTPUT}" | grep -q "would reformat"; then
            UNFORMATTED=$(echo "${FORMAT_OUTPUT}" | grep "would reformat" | wc -l)
            log_warn "${UNFORMATTED} file(s) need formatting:"
            echo "${FORMAT_OUTPUT}" | grep "would reformat" | while IFS= read -r line; do
                echo -e "    ${_D}${line}${_N}"
            done
            echo ""
            log_example "Auto-format: .venv/bin/ruff format core/ runner/ api/ cli/"
            WARNINGS=$((WARNINGS + 1))
        else
            log_success "Formatting OK"
        fi
    fi

else
    log_debug "Skipping ruff checks (branch: ${CURRENT_BRANCH}, only enforced on main)"
fi

# ── Check 4: Python debug leftovers ───────────────────────

log_debug "Checking for debug leftovers..."
for file in ${STAGED_PY}; do
    # Skip tests and configs
    case "${file}" in
        *test_*|*_test.py|*conftest*) continue ;;
    esac

    # breakpoint() and pdb
    if grep -qnE '(breakpoint\(\)|import pdb|pdb\.set_trace\(\))' "${file}" 2>/dev/null; then
        log_warn "Debug statement found: ${file}"
        grep -nE '(breakpoint\(\)|import pdb|pdb\.set_trace\(\))' "${file}" | while read -r line; do
            log_example "  ${line}"
        done
        WARNINGS=$((WARNINGS + 1))
    fi

    # Bare print() in non-CLI/script files
    case "${file}" in
        cli/*|scripts/*|runner/ci.py) continue ;;
    esac
    if grep -qnE '^\s*print\(' "${file}" 2>/dev/null; then
        log_warn "print() found (use logging or Rich instead?): ${file}"
        WARNINGS=$((WARNINGS + 1))
    fi
done

# ── Check 5: Sensitive files ──────────────────────────────

log_debug "Checking for sensitive files..."
for file in ${STAGED_FILES}; do
    case "${file}" in
        .env|.env.*|*.pem|*.key|*.p12|*.pfx)
            log_error "Sensitive file staged: ${file} — add it to .gitignore"
            ERRORS=$((ERRORS + 1))
            ;;
    esac
done

# ── Check 6: Large files (> 500 KB) ──────────────────────

log_debug "Checking file sizes..."
for file in ${STAGED_FILES}; do
    if [ -f "${file}" ]; then
        size=$(wc -c < "${file}" 2>/dev/null || echo 0)
        if [ "${size}" -gt 512000 ]; then
            size_kb=$((size / 1024))
            log_error "File too large (${size_kb} KB > 500 KB): ${file}"
            log_example "Consider .gitignore or Git LFS"
            ERRORS=$((ERRORS + 1))
        fi
    fi
done

# ── Check 7: __pycache__ and .venv ───────────────────────

log_debug "Checking for cache files..."
for file in ${STAGED_FILES}; do
    case "${file}" in
        *__pycache__*|*.pyc)
            log_error "Cache file staged: ${file} — should be in .gitignore"
            ERRORS=$((ERRORS + 1))
            ;;
        .venv/*)
            log_error "Virtual environment file staged: ${file} — should be in .gitignore"
            ERRORS=$((ERRORS + 1))
            ;;
    esac
done

# ── Summary ───────────────────────────────────────────────

echo ""
if [ ${ERRORS} -gt 0 ]; then
    log_error "${ERRORS} error(s) found — commit blocked"
    log_example "Fix the errors above or bypass with: SKIP_PRE_COMMIT=1 git commit ..."
    echo ""
    exit 1
fi

if [ ${WARNINGS} -gt 0 ]; then
    log_warn "${WARNINGS} warning(s) — commit allowed"
else
    log_success "All checks passed"
fi

echo ""
exit 0
